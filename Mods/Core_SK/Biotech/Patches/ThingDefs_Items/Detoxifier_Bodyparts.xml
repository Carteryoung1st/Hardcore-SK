<?xml version="1.0" encoding="utf-8" ?>
<Patch>

    <Operation Class="PatchOperationSequence">
        <operations>
            <li Class="SK.PatchOperationReplaceExtended">
                <xpath>Defs/RecipeDef[defName="InstallDetoxifierLung" or defName="InstallDetoxifierKidney"]</xpath>
                <value>
                    <researchPrerequisite>ToxFiltration</researchPrerequisite>
                </value>
            </li>
            
            <li Class="PatchOperationAttributeSet">
                <xpath>Defs/ThingDef[defName="DetoxifierLung" or defName="DetoxifierKidney"]</xpath>
                <attribute>ParentName</attribute>
                <value>SK.BodyPartBase_SyntheticDummy</value>
            </li>
            
            <li Class="SK.PatchOperationReplaceExtended">
                <xpath>Defs/ThingDef[defName="DetoxifierLung"]</xpath>
                <value>
                    <statBases>
                        <Mass>2</Mass>
                        <MaxHitPoints>75</MaxHitPoints>
                    </statBases>
                    <costList Replace="True">
                        <Biomatter>20</Biomatter>
                        <CarbonAlloy>5</CarbonAlloy>
                        <SyntheticFibers>8</SyntheticFibers>
                        <Microchips>2</Microchips>
                        <ComponentSpacer>2</ComponentSpacer>
                    </costList>
                    <recipeMaker Replace="True">
                        <productCount>1</productCount>
                        <skillRequirements>
                            <Crafting>10</Crafting>
                        </skillRequirements>
                        <researchPrerequisite>ToxFiltration</researchPrerequisite>
                    </recipeMaker>
                </value>
            </li>
            <li Class="SK.PatchOperationReplaceExtended">
                <xpath>Defs/ThingDef[defName="DetoxifierKidney"]</xpath>
                <value>
                    <statBases>
                        <Mass>1</Mass>
                        <MaxHitPoints>75</MaxHitPoints>
                    </statBases>
                    <costList Replace="True">
                        <Biomatter>15</Biomatter>
                        <CarbonAlloy>5</CarbonAlloy>
                        <SyntheticFibers>6</SyntheticFibers>
                        <Microchips>2</Microchips>
                        <ComponentSpacer>1</ComponentSpacer>
                    </costList>
                    <recipeMaker Replace="True">
                        <productCount>1</productCount>
                        <skillRequirements>
                            <Crafting>10</Crafting>
                        </skillRequirements>
                        <researchPrerequisite>ToxFiltration</researchPrerequisite>
                    </recipeMaker>
                </value>
            </li>
        </operations>
    </Operation>

</Patch>
